<odoo>

    <!-- List View -->
    <record id="student_list_view" model="ir.ui.view">
        <field name="name">student.list</field>
        <field name="model">custom.student</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="age"/>
                <field name="email"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="student_form_view" model="ir.ui.view">
        <field name="name">student.form</field>
        <field name="model">custom.student</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="age"/>
                        <field name="email"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="student_action" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">custom.student</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_student_root" name="Students" sequence="10" web_icon="base,static/description/icon.png"/>

    <menuitem id="menu_student_records" name="Student Records" parent="menu_student_root" action="student_action" sequence="1"/>

</odoo>
